# ---- Inference (Nebius Token Factory) ----
NEBIUS_API_KEY=XXX

# ---- MLflow tracking ----
# Where the DAG logs params/metrics/artifacts. With the Phase 3 docker-compose
# stack this is the MLflow service; for standalone Airflow use localhost.
# If unset, MLflow falls back to a local ./mlruns directory.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-agent-eval

# ---- Reference repos (optional override) ----
# Parent dir holding the sibling mini-swe-agent/ and SWE-bench/ checkouts.
# Leave unset to use the project's parent directory (the default layout).
# MSWEA_REPOS_DIR=/home/user

# ---- Object Storage (Nebius S3-compatible) -- Phase 4 ----
# Used to upload runs/<run-id>/ for long-term storage and log the URI to MLflow.
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
S3_BUCKET=mlops-eval-artifacts
S3_PREFIX=runs
AWS_ACCESS_KEY_ID=XXX
AWS_SECRET_ACCESS_KEY=XXX
AWS_REGION=eu-north1
