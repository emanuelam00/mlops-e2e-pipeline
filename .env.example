# ---- Inference (Nebius Token Factory) ----
NEBIUS_API_KEY=XXX

# ---- MLflow tracking ----
# Where the DAG logs params/metrics/artifacts. With the Phase 3 docker-compose
# stack this is the MLflow service; for standalone Airflow use localhost.
# If unset, MLflow falls back to a local ./mlruns directory.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-agent-eval

# ---- Reference repos (optional override) ----
# Parent dir holding the sibling mini-swe-agent/ and SWE-bench/ checkouts.
# Leave unset to use the project's parent directory (the default layout).
# MSWEA_REPOS_DIR=/home/user

# ---- Docker Compose deployment (Phase 3) ----
# Match the Airflow version you validated in standalone: `uv tool run apache-airflow version`.
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
# Run containers as your host user so files written to ./runs are owned by you.
# Set with:  echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000
# Host docker group gid, so Airflow can use the mounted socket.
# Find it with:  getent group docker | cut -d: -f3
DOCKER_GID=999
# Absolute HOST paths (the host docker daemon resolves DockerOperator mounts).
# HOST_PROJECT_DIR = this repo on the VM; HOST_PARENT_DIR = its parent (holds mini-swe-agent/).
HOST_PROJECT_DIR=/home/emanuel/mlops-e2e-pipeline
HOST_PARENT_DIR=/home/emanuel
# Name of the eval image built from the root Dockerfile (used by DockerOperator).
EVAL_IMAGE=mlops-eval:latest
# Compose network so DockerOperator eval containers can reach the mlflow service.
# Usually "<compose-project-name>_default"; the project name defaults to the repo
# dir name. Check with: docker network ls | grep default
COMPOSE_NETWORK=mlops-e2e-pipeline_default
# Airflow admin login created by airflow-init.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Shared JWT secret for Airflow 3.x internal auth (same value across services).
AIRFLOW_JWT_SECRET=change-me-to-a-random-string
# Optional: persist a Fernet key for connection encryption (else leave blank).
AIRFLOW_FERNET_KEY=

# ---- Object Storage (Nebius S3-compatible) -- Phase 4 ----
# Used to upload runs/<run-id>/ for long-term storage and log the URI to MLflow.
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
S3_BUCKET=mlops-eval-artifacts
S3_PREFIX=runs
AWS_ACCESS_KEY_ID=XXX
AWS_SECRET_ACCESS_KEY=XXX
AWS_REGION=eu-north1
